---
import BaseLayout from '../../layouts/BaseLayout.astro';

const { title, stylesHref = null, bodyClass } = Astro.props as {
  title: string;
  stylesHref?: string | readonly string[] | null;
  bodyClass?: string;
};

const stylesheetHrefs = Array.isArray(stylesHref)
  ? stylesHref.filter((href): href is string => typeof href === 'string' && href.length > 0)
  : typeof stylesHref === 'string' && stylesHref.length > 0
    ? [stylesHref]
    : [];
const resolvedBodyClass = ['admin-page', bodyClass].filter(Boolean).join(' ');
---

<BaseLayout title={title} bodyClass={resolvedBodyClass}>
  <Fragment slot="head">
    <meta name="robots" content="noindex,nofollow" />
    {stylesheetHrefs.map((href) => <link rel="stylesheet" href={href} />)}
    <slot name="head" />
  </Fragment>
  <slot />
</BaseLayout>
