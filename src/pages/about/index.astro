---
import { getEntry, render } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import BrandIcon from '../../components/BrandIcon.astro';
import '../../styles/about.css';
import { getThemeSettings, type SiteSocialIconKey } from '../../lib/theme-settings';

const entry = await getEntry('about', 'index');
if (!entry) {
  throw new Error('Missing about page entry: src/content/about/index.md');
}

const { Content } = await render(entry);
const { settings } = getThemeSettings();
const resolvedSocialItems = settings.site.socialLinks.resolvedSocialItems.filter((item) => item.visible);
const aboutTitle = settings.page.about.title || '关于';
const aboutSubtitle = settings.page.about.subtitle;

type ContactItem = {
  key: string;
  href: string;
  icon: SiteSocialIconKey;
  text: string;
};

const formatExternalLabel = (href: string): string => {
  try {
    const parsed = new URL(href);
    const path = parsed.pathname.replace(/^\/+|\/+$/g, '');
    return path || parsed.hostname;
  } catch {
    return href;
  }
};

const contactItems: ContactItem[] = [
  ...resolvedSocialItems.map((item) => ({
    key: item.id,
    href: item.href,
    icon: item.iconKey,
    text: item.id === 'email' ? item.href.replace(/^mailto:/i, '') : formatExternalLabel(item.href)
  }))
];
---

<BaseLayout
  title={aboutTitle}
  description={aboutSubtitle ?? undefined}
  bodyClass="about-page"
>
  <div class="page-header page-header--about">
    <div class="page-heading">
      <h1 class="page-title">{aboutTitle}</h1>
      {aboutSubtitle ? <span class="page-subtitle">{aboutSubtitle}</span> : null}
    </div>
    {
      resolvedSocialItems.length ? (
        <div class="page-actions">
          {resolvedSocialItems.map((item) => (
            <a class="icon-link" href={item.href} aria-label={item.label} title={item.label}>
              <BrandIcon name={item.iconKey} class="icon" />
            </a>
          ))}
        </div>
      ) : null
    }
  </div>

  <div class="about-body prose">
    <Content />
  </div>

  {
    contactItems.length ? (
      <section class="about-section about-contact" aria-labelledby="about-contact-title">
        <h2 id="about-contact-title" class="section-title about-section-title">联系与订阅</h2>
        <div class="contact-block" aria-label="联系方式">
          <ul class="contact-list">
            {contactItems.map((item) => (
              <li>
                <span class="contact-link-head" aria-hidden="true">
                  <BrandIcon name={item.icon} class="contact-icon" />
                </span>
                <a href={item.href}>{item.text}</a>
              </li>
            ))}
          </ul>
        </div>
      </section>
    ) : null
  }
</BaseLayout>
