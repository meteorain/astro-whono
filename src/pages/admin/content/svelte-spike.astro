---
import AdminLayout from '../../../components/admin/AdminLayout.astro';
import AdminReadonlyNotice from '../../../components/admin/AdminReadonlyNotice.astro';
import AdminShell from '../../../components/admin/AdminShell.astro';
import { ADMIN_PREVIEW_API_PATH } from '../../../lib/admin-console/admin-api-paths';
import { createWithBase } from '../../../utils/format';

const isDev = import.meta.env.DEV;
const shouldShowAdminNav = isDev;
const base = import.meta.env.BASE_URL ?? '/';
const withBase = createWithBase(base);
const { default: adminShellStylesHref } = await import('../../../styles/components/admin-shell.css?url');

const loadSvelteSpikeDevState = async () => {
  const { default: adminContentStylesHref } = await import('../../../styles/components/admin-content.css?url');

  return {
    stylesHref: [adminShellStylesHref, adminContentStylesHref]
  };
};

const svelteSpikeDevState = isDev ? await loadSvelteSpikeDevState() : null;
// Keep the spike island behind a DEV-only dynamic import so production builds
// do not emit its Svelte client chunk.
let SvelteSpikeIsland: any = null;
if (import.meta.env.DEV) {
  SvelteSpikeIsland = (await import('../../../components/admin/editor/SvelteSpikeIsland.astro')).default;
}
const adminStylesHref = svelteSpikeDevState?.stylesHref ?? adminShellStylesHref;
const initialSpikeContent = [
  '# Editor spike',
  '',
  '本页只验证 Svelte 5 island 的挂载、runes 状态与 TypeScript 编译。',
  '',
  '- textarea 状态在客户端维护',
  '- dirty 状态由 `$derived` 计算',
  `- 后续正文预览继续走 \`${ADMIN_PREVIEW_API_PATH}\``
].join('\n');
---

<AdminLayout title="Content Console Svelte Spike" stylesHref={adminStylesHref}>
  <AdminShell
    currentRoute="content"
    title="Content Console"
    subtitle="Svelte island spike"
    showNav={shouldShowAdminNav}
  >
    {
      isDev ? (
        <section class="admin-overview" data-admin-svelte-spike-page>
          <article class="admin-overview-card">
            <p class="admin-overview-card__eyebrow">DEV-only spike</p>
            <h2 class="admin-overview-card__title">Svelte 5 island 集成验证</h2>
            <p class="admin-overview-card__body">
              当前页面只承载技术 spike：验证 Astro integration、客户端挂载、TypeScript 与现有 Admin 样式契约。
            </p>
            <div class="admin-overview-card__actions">
              <a class="admin-btn admin-btn--ghost" href={withBase('/admin/content/')}>返回 Content 总入口</a>
            </div>
          </article>

          <article class="admin-overview-card">
            <SvelteSpikeIsland
              endpointLabel={withBase(ADMIN_PREVIEW_API_PATH)}
              initialContent={initialSpikeContent}
            />
          </article>
        </section>
      ) : (
        <AdminReadonlyNotice>
          若需查看或编辑内容索引，请在本地运行 <code translate="no">npm run dev</code> 后从此入口进入。
          Svelte island 验证页仅在本地开发态挂载。
        </AdminReadonlyNotice>
      )
    }
  </AdminShell>
</AdminLayout>
